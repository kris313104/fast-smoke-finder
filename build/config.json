{
  "listeners": [
    {
      "address": "0.0.0.0",
      "port": 8080,
      "https": false
    }
  ],
  "app": {
    "document_root": "./static",
    "upload_path": "./uploads",
    "threads_num": 4,
    "use_gzip": true,
    "static_files_cache_time": 86400,
    "file_types": [
      "html", "js", "css",
      "png", "jpg", "jpeg", "webp",
      "ico", "svg", "woff2", "woff"
    ],
"server_header_field": "QuickLineups/1.0",
    "idle_connection_timeout": 60
  }
}
